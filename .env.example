# Comma-separated list of account tokens to run simultaneously.
DISCORD_TOKENS=token1,token2

# Comma-separated guild IDs to watch across all accounts.
# Leave empty to watch every guild each account has access to.
WATCHED_GUILDS=

# Channel ID to mirror edits and deletes into. Whichever account
# has access to this channel will post there.
LOG_CHANNEL_ID=

# Optional dedicated token for posting to LOG_CHANNEL_ID.
# This account does not need to be in any WATCHED_GUILDS.
# If unset, the first account in DISCORD_TOKENS that can see LOG_CHANNEL_ID posts instead.
LOG_POSTER_TOKEN=

# Channel-to-webhook mirror pairs, comma-separated: channel_id:webhook_url
# Repeat a channel_id with different URLs to fan out to multiple webhooks.
# Messages are queued in SQLite and posted with the original author's avatar and username.
MIRROR_CHANNELS=
